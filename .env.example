ENVIRONMENT=development
POSTGRES_DB=neuroimagen
POSTGRES_USER=neuroimagen
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+psycopg://neuroimagen:change-me-in-production@postgres:5432/neuroimagen
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
STORAGE_ROOT=/app/data/studies
ALLOWED_EXTENSIONS=.nii,.nii.gz,.dcm,.zip,.tar,.tar.gz,.gz,.json,.txt
MAX_UPLOAD_SIZE_MB=1024
PROCESSOR_NAME=dummy-development-processor
PROCESSOR_VERSION=0.1.0
PROCESSOR_COMMAND=python /app/external_processor/dummy_processor.py --input {input_dir} --output {output_dir} --study-id {study_id}
PROCESSOR_BACKEND=dummy
COMPNEURO_CONTAINER_IMAGE=compneurobilbaolab/compneuro-anatproc:1.1
COMPNEURO_ANATPROC_REF=a2f3e7c9523ed521c3f85f7dffde5ee8fb400842
COMPNEURO_PROJECT_MOUNT=/project
COMPNEURO_COMMAND=bash /app/src/apreproc_launcher.sh
WORKER_DOCKERFILE=backend/Dockerfile
PROCESSING_TIMEOUT_SECONDS=0
MAX_CONCURRENT_PROCESSING_JOBS=1
GENERATE_OUTPUT_ZIP=true
GENERATE_TECHNICAL_PDF=true
BIDS_VALIDATE=false
CORS_ORIGINS=http://localhost,http://localhost:5173
