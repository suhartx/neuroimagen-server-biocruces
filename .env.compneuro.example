# Plantilla para ejecutar el backend real `compneuro-anatproc`.
# Copiar a `.env` y ajustar secretos/URLs locales antes de levantar servicios.

# Entorno de ejecución. En producción usar `production` y revisar secretos.
ENVIRONMENT=development

# Base de datos PostgreSQL creada por Docker Compose.
POSTGRES_DB=neuroimagen

# Usuario de PostgreSQL usado por API y worker.
POSTGRES_USER=neuroimagen

# Contraseña de PostgreSQL. Cambiar fuera de desarrollo local.
POSTGRES_PASSWORD=neuroimagen

# URL SQLAlchemy/psycopg usada por API y worker para conectarse a PostgreSQL.
DATABASE_URL=postgresql+psycopg://neuroimagen:neuroimagen@postgres:5432/neuroimagen

# Broker Redis donde FastAPI encola tareas Celery.
CELERY_BROKER_URL=redis://redis:6379/0

# Backend Redis usado por Celery para metadatos técnicos de resultado.
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Ruta interna compartida donde se guardan estudios, BIDS, resultados y logs.
STORAGE_ROOT=/app/data/studies

# Para compneuro se restringe la subida a T1w NIfTI comprimido.
ALLOWED_EXTENSIONS=.nii.gz

# Tamaño máximo de subida en MB.
MAX_UPLOAD_SIZE_MB=1024

# Selecciona el adapter real de compneuro en `processor_adapter`.
PROCESSOR_BACKEND=compneuro

# Nombre técnico registrado en estudios, PDF y trazabilidad.
PROCESSOR_NAME=compneuro-anatproc

# Versión técnica registrada del procesador externo.
PROCESSOR_VERSION=1.1

# Dockerfile del worker especializado, basado en la imagen de compneuro.
WORKER_DOCKERFILE=worker/Dockerfile.compneuro

# Imagen base documentada para trazabilidad operativa.
COMPNEURO_CONTAINER_IMAGE=compneurobilbaolab/compneuro-anatproc:1.1

# Commit del repositorio externo usado al construir el worker compneuro.
COMPNEURO_ANATPROC_REF=a2f3e7c9523ed521c3f85f7dffde5ee8fb400842

# Ruta interna esperada por los scripts de compneuro. No cambiar salvo adaptar el launcher.
COMPNEURO_PROJECT_MOUNT=/project

# Comando real que ejecuta el adapter. Mantener el launcher soportado salvo autorización explícita.
COMPNEURO_COMMAND=bash /app/src/apreproc_launcher.sh

# Timeout global del procesador en segundos. `0` significa sin timeout.
PROCESSING_TIMEOUT_SECONDS=0

# Réplicas del servicio worker. Con compneuro, esto define procesamientos simultáneos.
WORKER_REPLICAS=2

# Concurrencia interna por contenedor worker. Para compneuro debe quedar en `1`.
MAX_CONCURRENT_PROCESSING_JOBS=1

# Genera `output/outputs.zip` con los resultados descargables.
GENERATE_OUTPUT_ZIP=true

# Genera el PDF técnico propio de la plataforma.
GENERATE_TECHNICAL_PDF=true

# Renderiza resultados NIfTI a PNG para incluirlos en el PDF técnico.
GENERATE_RENDERED_PNG=true

# Comando de renderizado disponible dentro del worker compneuro; proviene de FSL.
NIFTI_RENDERER=slicer

# Máximo de ficheros NIfTI a renderizar por estudio.
NIFTI_RENDER_MAX_FILES=50

# Timeout por fichero renderizado, en segundos.
NIFTI_RENDER_TIMEOUT_SECONDS=300

# Nombre del PDF técnico dentro de `output/reports/`.
TECHNICAL_REPORT_FILENAME=technical_report.pdf

# Reservado para validación BIDS formal futura.
BIDS_VALIDATE=false

# Orígenes permitidos para llamadas del navegador a la API.
CORS_ORIGINS=http://localhost,http://localhost:5173

# Clave HMAC para JWT. Cambiar por una clave larga y privada fuera de desarrollo.
AUTH_SECRET_KEY=change-me-in-production

# Duración del access token local en minutos.
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480

# URL pública incluida en correos de notificación.
APP_PUBLIC_BASE_URL=http://100.114.173.115

# Activa envío SMTP además de notificaciones internas.
NOTIFICATIONS_EMAIL_ENABLED=true

# Servidor SMTP. En despliegue real usar el relay autorizado por la institución/proveedor.
SMTP_HOST=smtp-relay.brevo.com

# Puerto SMTP del relay.
SMTP_PORT=587

# Usuario SMTP. Completar solo en `.env`, no commitear credenciales reales.
SMTP_USERNAME=

# Contraseña/API key SMTP. Debe quedar vacía en ejemplos versionados.
SMTP_PASSWORD=

# Remitente autorizado/verificado por el servidor SMTP.
SMTP_FROM_EMAIL=

# Usa STARTTLS antes de autenticar contra el relay SMTP.
SMTP_USE_TLS=true
